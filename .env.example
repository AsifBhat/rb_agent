# Server-side only (Netlify env vars / local dev via vite.config.ts)
OPENAI_API_KEY=sk-proj-your-key-here

# Public workflow id from Agent Builder (safe to expose in frontend)
VITE_CHATKIT_WORKFLOW_ID=wf_your_workflow_id_here

# Optional: also set on Netlify for the serverless function
CHATKIT_WORKFLOW_ID=wf_your_workflow_id_here
